    "@medusajs/cli": "^2.5.0",
    "@medusajs/admin-sdk": "^2.5.0",
    "@medusajs/ui": "^4.0.0",
    "@medusajs/icons": "^2.0.0",
    "@swc/core": "^1.5.7",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@medusajs/framework": "^2.5.0",
    "@medusajs/medusa": "^2.5.0"
  }
