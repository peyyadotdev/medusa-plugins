    "./workflows/*": "./.medusa/server/src/workflows/*.js",
    "./*": "./.medusa/server/src/*.js"
  },
  "scripts": {
    "build": "medusa plugin:build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@medusajs/framework": "^2.5.0",
