{
  "name": "@peyya/medusa-plugin-settings",
  "version": "0.0.1",
  "description": "Shared encrypted settings storage and admin UI components for Medusa v2 plugins",
  "keywords": [
    "medusa-v2",
    "medusa-plugin-integration",
    "medusa-plugin-other"
  ],
  "files": [
    "dist",
    ".medusa"
  ],
  "exports": {
    "./package.json": "./package.json",
